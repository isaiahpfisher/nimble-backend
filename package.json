{
  "name": "nimble-backend",
  "version": "1.0.0",
  "description": "Nimble Node.js with Rest API",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "start": "node server.js",
    "init-db": "node scripts/init-db.js",
    "init-db:wipe": "node scripts/init-db.js --wipe",
    "init-db:keep": "node scripts/init-db.js --no-wipe",
    "bundle": "mkdir deploy && cp -r app server.js package.json package-lock.json nimble-backend.service .env deploy"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app/**/*.js",
      "!app/models/**",
      "!app/config/**",
      "!app/routes/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "keywords": [
    "node.js",
    "express",
    "sequelize"
  ],
  "author": "cs",
  "license": "ISC",
  "dependencies": {
    "auth-verify": "^1.14.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.22.2",
    "googleapis": "^118.0.0",
    "jest": "^29.3.1",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.2.3",
    "parse": "^4.0.1",
    "passport-github2": "^0.1.12",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.19.0",
    "supertest": "^6.3.3"
  }
}
